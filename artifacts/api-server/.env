# API Server Environment Variables - Development

# OpenAI API Key (optional - falls back to rule-based extraction if not set)
OPENAI_API_KEY=

# WhatsApp Configuration
WHATSAPP_ACCESS_TOKEN=test-token-for-development
VERIFY_TOKEN=test-verify-token

# Database - PostgreSQL
DATABASE_URL=postgresql://vendor:vendor123@localhost:5432/vendor_db

# Node Environment
NODE_ENV=development
