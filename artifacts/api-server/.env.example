# API Server Environment Variables

# OpenAI API Key for AI-powered order extraction
# Get your key at: https://platform.openai.com/api-keys
# If not set, bot falls back to rule-based extraction
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# WhatsApp Configuration
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-access-token
VERIFY_TOKEN=your-webhook-verification-token

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vendor_db

# Node Environment
NODE_ENV=development
