{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-server run build",
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/artifacts/api-server/dist/index.mjs",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    }
  ],
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
